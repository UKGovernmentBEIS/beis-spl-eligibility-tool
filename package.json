{
  "name": "beis-spl-eligibility-tool",
  "version": "0.0.1",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": "16.18.1",
    "npm": "8.15.x"
  },
  "scripts": {
    "compile": "grunt generate-assets",
    "clean": "grunt clean",
    "dev": "grunt",
    "server": "node ./start.js",
    "start": "npm run server",
    "watch": "./node_modules/.bin/grunt watch",
    "lint": "standard && sass-lint -v",
    "lint-sass": "./node_modules/.bin/sass-lint -v",
    "test": "standard && nyc node ./node_modules/mocha/bin/mocha \"!(node_modules)/**/*+(.test|.tests)\".js",
    "test:watch": "chokidar app common test *.js --initial -c \"npm run test\"",
    "test:start:a11y": "PA11Y_TEST=true NODE_ENV=test npm start &",
    "test:a11y": "NODE_PATH=. mocha test/accessibility/a11y --timeout 15000"
  },
  "browserslist": [
    "defaults or IE 11"
  ],
  "dependencies": {
    "@dvsa/cookie-manager": "^1.1.2",
    "body-parser": "1.20.x",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
