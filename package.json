    "dset": "^3.1.2",
    "express": "4.18.x",
    "express-session": "^1.17.3",
    "govuk-frontend": "^4.4.0",
    "jsdom": "^20.0.3",
    "lodash": "^4.17.21",
    "memorystore": "^1.6.7",
    "minimist": "^1.2.7",
    "moment": "^2.29.4",
    "morgan": "1.10.x",
    "nodemailer": "^6.8.0",
